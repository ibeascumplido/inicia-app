# Variables para el dashboard de Vercel (Project → Settings → Environment Variables)

MONGO_URL=mongodb+srv://usuario:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=menu_facturacion_inicia

# Opcional: CORS manual. Si no se define, Vercel usa VERCEL_URL automáticamente.
# CORS_ORIGINS=https://tu-app.vercel.app

# Email (opcional)
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# No definir REACT_APP_BACKEND_URL en Vercel (frontend y API comparten dominio).
